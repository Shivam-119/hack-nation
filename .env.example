# LLM Provider — OpenAI is primary
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Fallback (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Data source API keys (optional — gracefully degrade without them)
GITHUB_TOKEN=ghp_...
CRUNCHBASE_API_KEY=
PRODUCTHUNT_TOKEN=

# Reputation scanner — web-article background check
# Tavily is the default backend. With no TAVILY_API_KEY set it falls back to
# the bundled fixtures automatically, so tests/demos still run offline.
TAVILY_API_KEY=tvly-...
REPUTATION_PROVIDER=tavily          # tavily | mock
REPUTATION_RESULTS_PER_QUERY=10     # per query angle; Tavily caps at 20
REPUTATION_MAX_QUERIES=15
# Full-page extraction (Tavily /extract) — recovers claims a thin search
# snippet cannot ground. Set REPUTATION_EXTRACT=false to run snippets-only.
REPUTATION_EXTRACT=true
REPUTATION_EXTRACT_LIMIT=16         # max pages fetched in full, per subject
REPUTATION_EXTRACT_DEPTH=basic      # basic | advanced
REPUTATION_EXTRACT_CHARS=4000       # per-article text cap fed to the LLM

# --- Socials tool (Twitter/LinkedIn) ------------------------------------
# Providers default to "mock" -> the tool runs at $0 with no keys.
# Flip a provider to "apify" and set APIFY_TOKEN to use live data; Apify's
# free monthly credit covers both networks (self-caps at $5, no card).
SOCIALS_TWITTER_PROVIDER=mock      # mock | apify | twitterapi_io
SOCIALS_LINKEDIN_PROVIDER=mock     # mock | apify
APIFY_TOKEN=
# Verified free-tier friendly (apidojo/* return {"noResults":true} on free plans).
# The tweet actor also scrapes replies via a conversation_id: search — no separate actor.
APIFY_TWITTER_ACTOR=kaitoeasyapi/twitter-x-data-tweet-scraper-pay-per-result-cheapest
APIFY_LINKEDIN_ACTOR=apimaestro/linkedin-profile-posts
APIFY_LINKEDIN_COMMENTS_ACTOR=apimaestro/linkedin-post-comments-replies-engagements-scraper-no-cookies
# Optional pay-as-you-go swap for real-time X (needs a small prepaid balance):
TWITTERAPI_IO_KEY=
# Comment/reply scraping (real; the connection GRAPH stays mocked for now):
SOCIALS_COMMENT_LIMIT=20
# Identity check (who is this person? + prominence score). "mock" ($0) or
# "tavily" (reuses TAVILY_API_KEY above). Founder + post commenters are checked.
SOCIALS_IDENTITY_PROVIDER=mock     # mock | tavily
SOCIALS_MAX_IDENTITY_CHECKS=8
# Cost caps (keep live runs in pennies):
SOCIALS_POST_LIMIT=30
SOCIALS_FOLLOWER_SAMPLE=200

# Database
DATABASE_URL=sqlite+aiosqlite:///./vc_brain.db
